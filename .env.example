# Scalekit credentials
SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=

# AgentKit connection to expose as tools (gmail, github, slack, etc.)
SCALEKIT_CONNECTION_NAME=gmail
SCALEKIT_IDENTIFIER=user_123

# FastRouter OpenAI-compatible endpoint
FASTROUTER_API_KEY=
FASTROUTER_BASE_URL=https://api.fastrouter.ai/api/v1
FASTROUTER_MODEL=openai/gpt-4o

# Optional prompt override
USER_PROMPT=Fetch my last 5 unread emails and summarize them.
